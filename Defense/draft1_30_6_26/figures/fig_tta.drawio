<mxfile host="app.diagrams.net" type="device">
  <diagram name="TTA inference" id="tta">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="960" pageHeight="470" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="ttl" value="TTA: run the same image at multiple scales (+ horizontal flip), then merge (inference-time only)" style="text;html=1;fontFamily=Times New Roman;fontSize=13;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="10" width="780" height="24" as="geometry" /></mxCell>

        <mxCell id="img" value="PASTE:&#10;input image" style="rounded=0;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontFamily=Times New Roman;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="30" y="170" width="120" height="110" as="geometry" /></mxCell>

        <!-- three scale branches -->
        <mxCell id="s1" value="scale 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=12;" vertex="1" parent="1"><mxGeometry x="210" y="90" width="120" height="44" as="geometry" /></mxCell>
        <mxCell id="s2" value="scale 0.83" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=12;" vertex="1" parent="1"><mxGeometry x="210" y="204" width="120" height="44" as="geometry" /></mxCell>
        <mxCell id="s3" value="scale 0.67" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=12;" vertex="1" parent="1"><mxGeometry x="210" y="318" width="120" height="44" as="geometry" /></mxCell>
        <mxCell id="flip" value="+ horizontal flip" style="text;html=1;fontFamily=Times New Roman;fontSize=10;fontStyle=2;align=center;" vertex="1" parent="1"><mxGeometry x="205" y="140" width="130" height="16" as="geometry" /></mxCell>

        <mxCell id="det" value="CBAM + P2&#10;detector&#10;(imgsz 1280)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Times New Roman;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="390" y="180" width="130" height="90" as="geometry" /></mxCell>

        <mxCell id="merge" value="Merge&#10;(NMS)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="185" width="110" height="80" as="geometry" /></mxCell>

        <mxCell id="out" value="PASTE:&#10;detections" style="rounded=0;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontFamily=Times New Roman;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="710" y="170" width="110" height="110" as="geometry" /></mxCell>

        <mxCell id="cfg" value="Scales [1.0, 0.83, 0.67] with {original, horizontal flip}; model trained at 640 px.  Best at imgsz 1280: +1.6 pt mAP50, +5.4 pt mAP50-95, person miss-rate 14% &#8594; 10%.  imgsz 1920 degrades (cannot extrapolate 3&#215; the training resolution)." style="text;html=1;fontFamily=Times New Roman;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="30" y="360" width="930" height="46" as="geometry" /></mxCell>

        <mxCell id="e0a" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="img" target="s1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e0b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="img" target="s2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e0c" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="img" target="s3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1a" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="s1" target="det"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="s2" target="det"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e1c" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="s3" target="det"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="det" target="merge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="merge" target="out"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
