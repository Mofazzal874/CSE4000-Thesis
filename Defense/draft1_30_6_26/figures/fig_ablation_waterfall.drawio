        <mxCell id="lg3t" value="(bar height = change in AP50 from the previous model)" style="text;html=1;fontFamily=Times New Roman;fontSize=9;fontStyle=2;align=left;" vertex="1" parent="1"><mxGeometry x="220" y="372" width="360" height="16" as="geometry" /></mxCell>

        <mxCell id="msg" value="P2 is the driver (+0.0060 AP50, and the largest very-tiny-recall gain). CBAM is near-free: fewer parameters than the baseline and the lowest latency. Mamba shows no meaningful accuracy change (&#8722;0.0012 AP50, +0.0014 AR@100) at 2.8&#215; latency, so it is excluded from the deployed model." style="text;html=1;fontFamily=Times New Roman;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="30" y="398" width="640" height="44" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
