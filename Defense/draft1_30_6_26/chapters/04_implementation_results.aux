\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces Recommended CBAM~+~P2 model on the C2A test set: (a)~precision--recall curve and (b)~$F_1$ score against confidence threshold, from which the operating point is chosen.}}{31}{figure.caption.36}\protected@file@percent }
\newlabel{fig:curves}{{4.5}{31}{Recommended CBAM~+~P2 model on the C2A test set: (a)~precision--recall curve and (b)~$F_1$ score against confidence threshold, from which the operating point is chosen}{figure.caption.36}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces CBAM~+~P2 model: (a)~reliability diagram (expected calibration error $0.021$) and (b)~confusion matrix on the C2A test set.}}{32}{figure.caption.37}\protected@file@percent }
\newlabel{fig:calib}{{4.6}{32}{CBAM~+~P2 model: (a)~reliability diagram (expected calibration error $0.021$) and (b)~confusion matrix on the C2A test set}{figure.caption.37}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces The recommended detector on a dense collapsed-building scene from the C2A test set, shown as one unified comparison: (a)~ground-truth annotations, (b)~the standard 640-px pass, (c)~sliced inference, and (d)~sliced inference with test-time augmentation. Box counts are at the 0.25 review threshold. The sliced modes add detections along the rubble line where the smallest figures sit.}}{32}{figure.caption.38}\protected@file@percent }
\newlabel{fig:qualgrid}{{4.7}{32}{The recommended detector on a dense collapsed-building scene from the C2A test set, shown as one unified comparison: (a)~ground-truth annotations, (b)~the standard 640-px pass, (c)~sliced inference, and (d)~sliced inference with test-time augmentation. Box counts are at the 0.25 review threshold. The sliced modes add detections along the rubble line where the smallest figures sit}{figure.caption.38}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.8}{\ignorespaces Detection-cell granularity on a C2A cluster crop, with detected boxes overlaid: the stride-8 (P3) grid~(a) covers several neighbouring people per cell, whereas the stride-4 (P2) grid~(b) resolves them individually. This is the spatial reason the added P2 scale recovers more of the smallest targets.}}{33}{figure.caption.39}\protected@file@percent }
\newlabel{fig:detgrid}{{4.8}{33}{Detection-cell granularity on a C2A cluster crop, with detected boxes overlaid: the stride-8 (P3) grid~(a) covers several neighbouring people per cell, whereas the stride-4 (P2) grid~(b) resolves them individually. This is the spatial reason the added P2 scale recovers more of the smallest targets}{figure.caption.39}{}}
