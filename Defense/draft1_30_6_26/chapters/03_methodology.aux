\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces High-level schematic of the proposed detection pipeline. An aerial image passes through the YOLO11m backbone, the CBAM attention block, and a PAN--FPN neck extended to stride~4; a four-scale head and NMS produce the final detections. Red-dashed elements mark the two proposed modifications.}}{14}{figure.caption.17}\protected@file@percent }
\newlabel{fig:framework}{{3.1}{14}{High-level schematic of the proposed detection pipeline. An aerial image passes through the YOLO11m backbone, the CBAM attention block, and a PAN--FPN neck extended to stride~4; a four-scale head and NMS produce the final detections. Red-dashed elements mark the two proposed modifications}{figure.caption.17}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.3}Proposed System Architecture}{14}{section.3.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3.1}Data Preprocessing}{14}{subsection.3.3.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces Layer-level architecture of the proposed YOLO11m~+~CBAM~+~P2 detector on a real C2A scene. The backbone extracts the P2--P5 feature pyramid; CBAM (red-dashed) replaces the C2PSA block at P5; the FPN and PAN passes fuse four levels, with the new stride-4 branch marked in red; the four-scale head and NMS produce the detections. The insets show the model's actual input, spatial attention, P2 feature response, and output on this scene.}}{15}{figure.caption.18}\protected@file@percent }
\newlabel{fig:fullarch}{{3.2}{15}{Layer-level architecture of the proposed YOLO11m~+~CBAM~+~P2 detector on a real C2A scene. The backbone extracts the P2--P5 feature pyramid; CBAM (red-dashed) replaces the C2PSA block at P5; the FPN and PAN passes fuse four levels, with the new stride-4 branch marked in red; the four-scale head and NMS produce the detections. The insets show the model's actual input, spatial attention, P2 feature response, and output on this scene}{figure.caption.18}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3.2}Attention Enhancement: CBAM}{15}{subsection.3.3.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3.1}{\ignorespaces Layer configuration of the proposed detector (640-px input). Channel counts are the values realised at the YOLO11m scale (width 1.0, channel cap 512, depth 0.5). Bold rows are the elements added or modified in this work.}}{16}{table.caption.19}\protected@file@percent }
\newlabel{tab:layers}{{3.1}{16}{Layer configuration of the proposed detector (640-px input). Channel counts are the values realised at the YOLO11m scale (width 1.0, channel cap 512, depth 0.5). Bold rows are the elements added or modified in this work}{table.caption.19}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3.3}Multi-Scale Detection: the P2 Head}{16}{subsection.3.3.3}\protected@file@percent }
