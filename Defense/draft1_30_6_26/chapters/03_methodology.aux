\newlabel{sec:mamba}{{3.3.4}{16}{State-Space Neck Variant: C3k2Mamba}{subsection.3.3.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.3.5}Running Example}{17}{subsection.3.3.5}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3.4}Architecture Novelties}{17}{section.3.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.1}Attention That Pays for Itself}{17}{subsection.3.4.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces The trained CBAM~+~P2 detector on the running-example collapsed-building scene: (a)~the letterbox-resized input; (b)~the CBAM spatial-attention map (warm~=~high attention), concentrated on human-shaped regions rather than the surrounding debris; (c)~the P2 stride-4 feature response, strongest at the smallest scattered figures; and (d)~the final human detections. The attention map and the P2 feature are read directly from the model's activations on this image.}}{18}{figure.caption.20}\protected@file@percent }
\newlabel{fig:explain}{{3.3}{18}{The trained CBAM~+~P2 detector on the running-example collapsed-building scene: (a)~the letterbox-resized input; (b)~the CBAM spatial-attention map (warm~=~high attention), concentrated on human-shaped regions rather than the surrounding debris; (c)~the P2 stride-4 feature response, strongest at the smallest scattered figures; and (d)~the final human detections. The attention map and the P2 feature are read directly from the model's activations on this image}{figure.caption.20}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Effect of the CBAM substitution. The schematic tiles (left) illustrate the mechanism: channel and spatial attention suppress background clutter and amplify the faint target response. The right panel shows the trained model's actual spatial-attention map on a C2A scene, concentrated on the scattered people rather than the rubble.}}{18}{figure.caption.21}\protected@file@percent }
\newlabel{fig:cbameffect}{{3.4}{18}{Effect of the CBAM substitution. The schematic tiles (left) illustrate the mechanism: channel and spatial attention suppress background clutter and amplify the faint target response. The right panel shows the trained model's actual spatial-attention map on a C2A scene, concentrated on the scattered people rather than the rubble}{figure.caption.21}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.5}{\ignorespaces The stride problem motivating the P2 head: the same $\sim $12-px human under each scale's detection grid. All four panels show one $32\times 32$-px image patch (a single P5 cell); the target covers about 0.4 of a P5 cell, 0.75 of a P4 cell, and 1.5 P3 cells, but roughly three cells of the added stride-4 P2 grid (red), enough for precise localisation.}}{19}{figure.caption.22}\protected@file@percent }
\newlabel{fig:strideprob}{{3.5}{19}{The stride problem motivating the P2 head: the same $\sim $12-px human under each scale's detection grid. All four panels show one $32\times 32$-px image patch (a single P5 cell); the target covers about 0.4 of a P5 cell, 0.75 of a P4 cell, and 1.5 P3 cells, but roughly three cells of the added stride-4 P2 grid (red), enough for precise localisation}{figure.caption.22}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.2}A Detection Scale Where the Targets Are}{19}{subsection.3.4.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {3.4.3}Single-Variable Additive Design}{19}{subsection.3.4.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {3.2}{\ignorespaces The additive ablation. Each configuration differs from the previous one by a single architectural change, isolating the contribution of attention, multi-scale detection, and the state-space neck.}}{20}{table.caption.23}\protected@file@percent }
\newlabel{tab:variants}{{3.2}{20}{The additive ablation. Each configuration differs from the previous one by a single architectural change, isolating the contribution of attention, multi-scale detection, and the state-space neck}{table.caption.23}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.5}Loss Function Design}{20}{section.3.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces The SAHI inference pipeline on a C2A scene: the input image is sliced into overlapping tiles (plus one full-image pass), the CBAM~+~P2 detector runs on each tile at a low confidence floor, and the per-tile detections are merged by greedy non-maximum merging into the final output.}}{21}{figure.caption.24}\protected@file@percent }
\newlabel{fig:sahipipe}{{3.6}{21}{The SAHI inference pipeline on a C2A scene: the input image is sliced into overlapping tiles (plus one full-image pass), the CBAM~+~P2 detector runs on each tile at a low confidence floor, and the per-tile detections are merged by greedy non-maximum merging into the final output}{figure.caption.24}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3.6}Inference-Time Enhancement: SAHI and TTA}{21}{section.3.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces The test-time augmentation pipeline: the input image is evaluated at three scales, each with a horizontal flip, by the same CBAM~+~P2 detector at 1280-px input, and the merged predictions are reduced by NMS to the final detections.}}{22}{figure.caption.25}\protected@file@percent }
\newlabel{fig:ttapipe}{{3.7}{22}{The test-time augmentation pipeline: the input image is evaluated at three scales, each with a horizontal flip, by the same CBAM~+~P2 detector at 1280-px input, and the merged predictions are reduced by NMS to the final detections}{figure.caption.25}{}}
