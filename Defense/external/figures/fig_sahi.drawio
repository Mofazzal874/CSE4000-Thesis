<mxfile host="app.diagrams.net" type="device">
  <diagram name="SAHI inference" id="sahi">
    <mxGraphModel dx="1000" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="ttl" value="SAHI: slice the image into overlapping tiles, detect on each, then merge (inference-time only)" style="text;html=1;fontFamily=Times New Roman;fontSize=13;fontStyle=1;align=left;" vertex="1" parent="1"><mxGeometry x="30" y="10" width="760" height="24" as="geometry" /></mxCell>

        <mxCell id="img" value="PASTE:&#10;full image" style="rounded=0;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontFamily=Times New Roman;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="30" y="150" width="130" height="110" as="geometry" /></mxCell>

        <mxCell id="slicer" value="Slicer&#10;overlapping tiles&#10;+ full image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="165" width="120" height="80" as="geometry" /></mxCell>

        <!-- overlapping tile grid (centrepiece) -->
        <mxCell id="grid" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#82b366;dashed=1;" vertex="1" parent="1"><mxGeometry x="360" y="120" width="160" height="170" as="geometry" /></mxCell>
        <mxCell id="t1" value="" style="rounded=0;fillColor=#d5e8d4;strokeColor=#82b366;opacity=70;" vertex="1" parent="1"><mxGeometry x="370" y="130" width="80" height="80" as="geometry" /></mxCell>
        <mxCell id="t2" value="" style="rounded=0;fillColor=#cfe6cd;strokeColor=#82b366;opacity=70;" vertex="1" parent="1"><mxGeometry x="430" y="130" width="80" height="80" as="geometry" /></mxCell>
        <mxCell id="t3" value="" style="rounded=0;fillColor=#cfe6cd;strokeColor=#82b366;opacity=70;" vertex="1" parent="1"><mxGeometry x="370" y="190" width="80" height="80" as="geometry" /></mxCell>
        <mxCell id="t4" value="" style="rounded=0;fillColor=#c3e0c0;strokeColor=#82b366;opacity=70;" vertex="1" parent="1"><mxGeometry x="430" y="190" width="80" height="80" as="geometry" /></mxCell>
        <mxCell id="gridLbl" value="overlapping tiles" style="text;html=1;fontFamily=Times New Roman;fontSize=10;fontStyle=2;align=center;" vertex="1" parent="1"><mxGeometry x="360" y="294" width="160" height="16" as="geometry" /></mxCell>

        <mxCell id="det" value="CBAM + P2&#10;detector&#10;(per tile, conf 0.15)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontFamily=Times New Roman;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="160" width="130" height="90" as="geometry" /></mxCell>

        <mxCell id="merge" value="Merge&#10;GREEDYNMM&#10;(IOS, thr 0.5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontFamily=Times New Roman;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="730" y="160" width="120" height="90" as="geometry" /></mxCell>

        <mxCell id="out" value="PASTE:&#10;merged detections" style="rounded=0;dashed=1;fillColor=#f5f5f5;strokeColor=#999999;fontFamily=Times New Roman;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="880" y="150" width="100" height="110" as="geometry" /></mxCell>

        <mxCell id="cfg" value="Configurations swept: slice 256 / 320 / 512 / 640 px, overlap 25&#8211;30%, tile conf 0.15&#8211;0.20, full-image pass on.  Best balance: 512 px (F1 0.866, very-tiny recall 0.808); best very-tiny recall: 256 px (0.829)." style="text;html=1;fontFamily=Times New Roman;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="30" y="350" width="950" height="40" as="geometry" /></mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="img" target="slicer"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="slicer" target="grid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="grid" target="det"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="det" target="merge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="merge" target="out"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
