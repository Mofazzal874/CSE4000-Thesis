<mxfile host="app.diagrams.net" type="device">
  <diagram name="Overall Framework" id="overall-framework">
    <mxGraphModel dx="1100" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title (delete before export if the LaTeX caption is used instead) -->
        <mxCell id="title" value="Overall framework of the proposed CBAM + P2 detector (YOLO11m backbone)" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="360" y="20" width="880" height="30" as="geometry" />
        </mxCell>

        <!-- Input -->
        <mxCell id="n_in" value="Aerial / Drone&#10;Image" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="220" width="130" height="70" as="geometry" />
        </mxCell>

        <!-- Preprocessing -->
        <mxCell id="n_pre" value="Preprocessing&#10;(letterbox resize&#10;&#8594; 640 &#215; 640)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="210" y="220" width="140" height="70" as="geometry" />
        </mxCell>

        <!-- Backbone -->
        <mxCell id="n_bb" value="YOLO11m Backbone&#10;(Conv + C3k2 stages, P1&#8594;P5)&#10;&#10;C2PSA &#8594; CBAM attention&#10;(after SPPF)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="390" y="185" width="200" height="140" as="geometry" />
        </mxCell>

        <!-- Neck -->
        <mxCell id="n_neck" value="PAN&#8211;FPN Neck&#10;(top-down + bottom-up&#10;multi-scale feature fusion,&#10;C3k2 blocks)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="630" y="200" width="180" height="110" as="geometry" />
        </mxCell>

        <!-- Detection head container -->
        <mxCell id="n_head" value="4-Scale Detection Head" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;verticalAlign=top;spacingTop=6;" vertex="1" parent="1">
          <mxGeometry x="850" y="120" width="220" height="270" as="geometry" />
        </mxCell>
        <mxCell id="h_p2" value="P2 &#8211; stride 4 (160&#215;160)&#10;tiny objects (&lt; 16 px)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="865" y="150" width="190" height="45" as="geometry" />
        </mxCell>
        <mxCell id="h_p3" value="P3 &#8211; stride 8 (80&#215;80)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="865" y="205" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_p4" value="P4 &#8211; stride 16 (40&#215;40)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="865" y="255" width="190" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h_p5" value="P5 &#8211; stride 32 (20&#215;20)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="865" y="305" width="190" height="40" as="geometry" />
        </mxCell>

        <!-- NMS -->
        <mxCell id="n_nms" value="NMS&#10;(post-processing)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1110" y="220" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- Output -->
        <mxCell id="n_out" value="Detected humans&#10;(bounding boxes)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1270" y="220" width="150" height="70" as="geometry" />
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n_in" target="n_pre"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n_pre" target="n_bb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n_bb" target="n_neck"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n_neck" target="n_head"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=1;exitY=0.5;" edge="1" parent="1" source="h_p2" target="n_nms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=1;exitY=0.5;" edge="1" parent="1" source="h_p3" target="n_nms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=1;exitY=0.5;" edge="1" parent="1" source="h_p4" target="n_nms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;exitX=1;exitY=0.5;" edge="1" parent="1" source="h_p5" target="n_nms"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;" edge="1" parent="1" source="n_nms" target="n_out"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
