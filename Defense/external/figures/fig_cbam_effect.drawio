        <mxCell id="cbeLegTarget" value="" style="ellipse;html=1;fillColor=#ff6666;strokeColor=#cc0000;" vertex="1" parent="1"><mxGeometry x="180" y="250" width="22" height="15" as="geometry" /></mxCell>
        <mxCell id="cbeLegTargetTxt" value="target response" style="text;html=1;fontFamily=Times New Roman;fontSize=10;align=left;" vertex="1" parent="1"><mxGeometry x="208" y="249" width="120" height="16" as="geometry" /></mxCell>

        <mxCell id="cbeNote" value="The tiles illustrate the mechanism; the right panel is the model&#39;s real spatial-attention map. CBAM down-weights background clutter (flood, rubble) and amplifies faint human responses, improving recall at near-zero parameter cost." style="text;html=1;fontFamily=Times New Roman;fontSize=10;align=left;verticalAlign=top;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="278" width="680" height="44" as="geometry" /></mxCell>
