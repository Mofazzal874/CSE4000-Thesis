        <mxCell id="cbeEdge1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="cbeBeforeTile" target="cbeBox"><mxGeometry relative="1" as="geometry" /></mxCell>
