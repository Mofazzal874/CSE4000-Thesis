        <mxCell id="cbeAfterLabel" value="Feature after CBAM" style="text;html=1;fontFamily=Times New Roman;fontSize=10;align=center;" vertex="1" parent="1"><mxGeometry x="330" y="208" width="150" height="16" as="geometry" /></mxCell>

        <mxCell id="cbeSlot" value="PASTE:&#10;cbam_overlay.png&#10;(real attention map,&#10;warm = high)" style="rounded=0;dashed=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontFamily=Times New Roman;fontSize=10;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="525" y="55" width="150" height="150" as="geometry" /></mxCell>
