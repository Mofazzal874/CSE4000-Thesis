        <mxCell id="cbeAfterTile" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="330" y="55" width="150" height="150" as="geometry" /></mxCell>
