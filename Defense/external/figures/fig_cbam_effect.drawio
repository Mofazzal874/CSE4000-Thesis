        <mxCell id="cbeBox" value="CBAM&#10;channel + spatial&#10;attention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Times New Roman;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="200" y="102" width="100" height="56" as="geometry" /></mxCell>
