print(f"\n🔍 Running Detailed Test Set Evaluation...")

# Test on 30 images
n_test_images = min(30, len(test_sampled))
test_images_to_eval = test_sampled[:n_test_images]

detailed_results = []

for img_file in tqdm(test_images_to_eval, desc="Evaluating test images"):
    img_path = f"{dataset_path}/test/images/{img_file}"
    label_path = f"{dataset_path}/test/labels/{img_file.replace('.png', '.txt').replace('.jpg', '.txt')}"
    
    # Get ground truth
    if os.path.exists(label_path):
        with open(label_path, 'r') as f:
            gt_boxes = len(f.readlines())
    else:
        gt_boxes = 0
    
    # Run prediction
    start_time = time.time()
    pred_results = model.predict(img_path, conf=0.25, verbose=False)
    inference_time = (time.time() - start_time) * 1000
    
    n_predictions = len(pred_results[0].boxes)
    
    # Confidence scores
    if n_predictions > 0:
        confidences = pred_results[0].boxes.conf.cpu().numpy()
        avg_conf = np.mean(confidences)
        max_conf = np.max(confidences)
        min_conf = np.min(confidences)
    else:
        avg_conf = max_conf = min_conf = 0.0
    
    # Simple TP/FP/FN calculation
    tp = min(n_predictions, gt_boxes)
    fp = max(0, n_predictions - gt_boxes)
    fn = max(0, gt_boxes - n_predictions)
    
    precision = tp / (tp + fp + 1e-10)
    recall = tp / (tp + fn + 1e-10)
    f1 = 2 * precision * recall / (precision + recall + 1e-10)
    
    detailed_results.append({
        'Image': img_file,
        'GT_Boxes': gt_boxes,
        'Pred_Boxes': n_predictions,
        'TP': tp,
        'FP': fp,
        'FN': fn,
        'Precision': round(precision, 4),
        'Recall': round(recall, 4),
        'F1': round(f1, 4),
        'Avg_Confidence': round(avg_conf, 4),
        'Max_Confidence': round(max_conf, 4),
        'Min_Confidence': round(min_conf, 4),
        'Inference_ms': round(inference_time, 2)
    })

# Create DataFrame
detailed_test_df = pd.DataFrame(detailed_results)

