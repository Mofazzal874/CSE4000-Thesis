    axes[idx].imshow(cv2.cvtColor(img_with_boxes, cv2.COLOR_BGR2RGB))
    axes[idx].axis('off')
    
    # Add info
    n_detections = len(pred_results[0].boxes)
    axes[idx].set_title(f'GT:{gt_count} | Pred:{n_detections}', fontsize=10, fontweight='bold')

# Hide unused subplots
for idx in range(n_viz_images, len(axes)):
    axes[idx].axis('off')

plt.suptitle(f'{FULL_MODEL_NAME} - Test Set Predictions', fontsize=16, fontweight='bold')
plt.tight_layout()

save_path = f"{PLOTS_DIR}/{FULL_MODEL_NAME}_test_predictions.png"
plt.savefig(save_path, dpi=150, bbox_inches='tight')
plt.show()
plt.close()

print(f"🖼️ Prediction visualizations saved to: {save_path}")


print(f"\n🖼️ Generating validation set prediction visualizations...")

# Select validation images for visualization
n_val_viz = min(15, len(val_sampled))
val_viz_images = val_sampled[:n_val_viz]

# Create grid
fig, axes = plt.subplots(n_rows, n_cols, figsize=(20, 4*n_rows))
axes = axes.flatten() if n_val_viz > 1 else [axes]

for idx, img_file in enumerate(val_viz_images):
    img_path = f"{dataset_path}/val/images/{img_file}"
    label_path = f"{dataset_path}/val/labels/{img_file.replace('.png', '.txt').replace('.jpg', '.txt')}"
    
    # Get GT count
    if os.path.exists(label_path):
        with open(label_path, 'r') as f:
            gt_count = len(f.readlines())
    else:
        gt_count = 0
    
    # Run prediction
    pred_results = model.predict(img_path, conf=0.25, verbose=False)
    
    # Plot
    img_with_boxes = pred_results[0].plot()
    axes[idx].imshow(cv2.cvtColor(img_with_boxes, cv2.COLOR_BGR2RGB))
    axes[idx].axis('off')
    
    # Add info
    n_detections = len(pred_results[0].boxes)
    axes[idx].set_title(f'GT:{gt_count} | Pred:{n_detections}', fontsize=10, fontweight='bold')

# Hide unused subplots
for idx in range(n_val_viz, len(axes)):
    axes[idx].axis('off')

plt.suptitle(f'{FULL_MODEL_NAME} - Validation Set Predictions', fontsize=16, fontweight='bold')
plt.tight_layout()
save_path = f"{PLOTS_DIR}/{FULL_MODEL_NAME}_val_predictions.png"
plt.savefig(save_path, dpi=150, bbox_inches='tight')
plt.show()
plt.close()
print(f"🖼️ Validation predictions saved to: {save_path}")


