# Set random seed for reproducibility
np.random.seed(42)

def sample_dataset(source_dir, dest_dir, ratio=0.5):
    """Sample a fraction of the dataset"""
    os.makedirs(dest_dir, exist_ok=True)
    
    all_files = [f for f in os.listdir(source_dir) if f.endswith(('.png', '.jpg', '.jpeg'))]
    sample_size = int(len(all_files) * ratio)
    sampled_files = np.random.choice(all_files, sample_size, replace=False)
    
    with open(f"{dest_dir}_files.txt", "w") as f:
        f.write("\n".join([os.path.join(source_dir, fname) for fname in sampled_files]))
    
    return sampled_files, len(all_files), sample_size

# Sample train, val, test sets
