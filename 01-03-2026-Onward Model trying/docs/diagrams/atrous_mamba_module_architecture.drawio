        <mxCell id="in_br2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#333;" edge="1" source="a_input" target="br2_part" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="in_br3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;strokeColor=#333;" edge="1" source="a_input" target="br3_part" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ============ GATED FUSION ============ -->
        <mxCell id="fusion_label" value="&lt;b&gt;Gated Fusion&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#d32f2f;fontStyle=5;" vertex="1" parent="1">
          <mxGeometry x="650" y="690" width="300" height="25" as="geometry" />
        </mxCell>

        <mxCell id="f_concat" value="&lt;b&gt;Concat&lt;/b&gt;&lt;br&gt;[out₁, out₂, out₃]&lt;br&gt;(B, 3×C, H, W)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="720" width="280" height="45" as="geometry" />
        </mxCell>

        <!-- Two parallel paths from concat -->
        <mxCell id="f_gate_conv" value="&lt;b&gt;Conv 1×1&lt;/b&gt;&lt;br&gt;3C → C&lt;br&gt;→ Sigmoid&lt;br&gt;&lt;b&gt;(gate)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#ad1457;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="790" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="f_proj_conv" value="&lt;b&gt;Conv 1×1&lt;/b&gt;&lt;br&gt;3C → C&lt;br&gt;&lt;b&gt;(projection)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3f51b5;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="910" y="790" width="130" height="60" as="geometry" />
        </mxCell>

        <!-- Gated combination -->
        <mxCell id="f_gated" value="&lt;b&gt;fused × gate&lt;/b&gt;&lt;br&gt;+ x × (1 - gate)&lt;br&gt;&lt;i&gt;(learnable skip connection)&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9c4;strokeColor=#f9a825;fontSize=10;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="660" y="880" width="280" height="50" as="geometry" />
        </mxCell>

        <!-- Original input skip to gated -->
        <mxCell id="f_skip_label" value="&lt;font color=&quot;#999&quot;&gt;&lt;i&gt;original input x&lt;br&gt;(skip connection)&lt;/i&gt;&lt;/font&gt;" style="text;html=1;align=center;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="1130" y="500" width="100" height="35" as="geometry" />
        </mxCell>

        <!-- LayerNorm out -->
        <mxCell id="f_outnorm" value="&lt;b&gt;LayerNorm&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="720" y="955" width="160" height="30" as="geometry" />
        </mxCell>

        <!-- Output -->
        <mxCell id="a_output" value="&lt;b&gt;Output&lt;/b&gt;&lt;br&gt;(B, C, H, W)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="720" y="1010" width="160" height="40" as="geometry" />
        </mxCell>

        <!-- Fusion arrows -->
        <mxCell id="fa1" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="br1_out" target="f_concat" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa2" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="br2_out" target="f_concat" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa3" style="edgeStyle=orthogonalEdgeStyle;strokeWidth=2;" edge="1" source="br3_out" target="f_concat" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_concat" target="f_gate_conv" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_concat" target="f_proj_conv" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_gate_conv" target="f_gated" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_proj_conv" target="f_gated" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa8" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_gated" target="f_outnorm" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="fa9" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="f_outnorm" target="a_output" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Skip connection arrow (original x) -->
        <mxCell id="fa_skip" style="edgeStyle=elbowEdgeStyle;dashed=1;strokeColor=#999;strokeWidth=2;" edge="1" source="a_input" target="f_gated" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1170" y="905" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- DILATED SCANNING VISUALIZATION -->
        <!-- ============================================================ -->
        <mxCell id="vis_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="30" y="700" width="350" height="420" as="geometry" />
        </mxCell>
        <mxCell id="vis_title" value="&lt;b&gt;Dilated Scanning Pattern Visualization&lt;/b&gt;&lt;br&gt;Example: 8×8 feature map, ws=4" style="text;html=1;align=center;fontSize=11;fontColor=#e65100;" vertex="1" parent="1">
          <mxGeometry x="40" y="705" width="330" height="35" as="geometry" />
        </mxCell>

        <mxCell id="vis_d1" value="&lt;b&gt;d=1: Standard&lt;/b&gt;&lt;br&gt;■ ■ ■ ■ □ □ □ □&lt;br&gt;■ ■ ■ ■ □ □ □ □&lt;br&gt;■ ■ ■ ■ □ □ □ □&lt;br&gt;■ ■ ■ ■ □ □ □ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;&lt;i&gt;4×4 contiguous window&lt;br&gt;LOCAL context only&lt;/i&gt;" style="text;html=1;align=center;fontSize=10;fontColor=#2e7d32;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="45" y="750" width="160" height="160" as="geometry" />
        </mxCell>

        <mxCell id="vis_d2" value="&lt;b&gt;d=2: Dilated&lt;/b&gt;&lt;br&gt;■ □ ■ □ ■ □ ■ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;■ □ ■ □ ■ □ ■ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;■ □ ■ □ ■ □ ■ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;&lt;i&gt;Skip every other token&lt;br&gt;MEDIUM-range context&lt;/i&gt;" style="text;html=1;align=center;fontSize=10;fontColor=#1565c0;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="215" y="750" width="160" height="160" as="geometry" />
        </mxCell>

        <mxCell id="vis_d4" value="&lt;b&gt;d=4: Wide Dilated&lt;/b&gt;&lt;br&gt;■ □ □ □ ■ □ □ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;■ □ □ □ ■ □ □ □&lt;br&gt;□ □ □ □ □ □ □ □&lt;br&gt;&lt;i&gt;Skip every 3 tokens&lt;br&gt;LONG-range context&lt;/i&gt;" style="text;html=1;align=center;fontSize=10;fontColor=#ad1457;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="120" y="920" width="170" height="160" as="geometry" />
        </mxCell>

        <!-- ============================================================ -->
        <!-- KEY DIFFERENCES BOX -->
        <!-- ============================================================ -->
        <mxCell id="diff_box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#666;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="430" y="1140" width="800" height="130" as="geometry" />
        </mxCell>
        <mxCell id="diff_title" value="&lt;b&gt;AtrousSSM vs Standard Mamba — Key Differences&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="430" y="1145" width="800" height="25" as="geometry" />
        </mxCell>
        <mxCell id="diff_text" value="&lt;b&gt;Standard Mamba (LocalWindowSSM):&lt;/b&gt; 1 branch, standard ws×ws window partition, bidirectional scan, no gating fusion&lt;br&gt;&lt;b&gt;AtrousSSM:&lt;/b&gt; 3 parallel branches with dilations [1,2,4], each has own weights, dilated window partition, gated fusion with learnable skip&lt;br&gt;&lt;br&gt;&lt;b&gt;Params:&lt;/b&gt; AtrousSSM adds ~4.56M (+23%) params due to 3× branch weights + fusion layers&lt;br&gt;&lt;b&gt;Speed:&lt;/b&gt; 2.3× slower (105ms vs 46ms) due to 3 sequential branches + fusion overhead&lt;br&gt;&lt;b&gt;Placement:&lt;/b&gt; AtrousSSM at 3 neck layers (13, 25, 28) vs standard Mamba at 6 neck layers (13, 16, 19, 22, 25, 28)" style="text;html=1;align=left;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="440" y="1170" width="780" height="95" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
